{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/build-groups.mjs",
    "dev": "node scripts/build-groups.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "npx wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "pages:deploy": "npx wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/typography": "^0.5.19",
    "js-yaml": "^4.1.1",
    "leaflet": "^1.9.4",
    "next": "^15.5.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
